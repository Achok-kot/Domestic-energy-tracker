# EnergyIQ Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to GitHub.

# EIA API Key - free at https://www.eia.gov/opendata/register.php
EIA_API_KEY=your_eia_api_key_here

# Electricity Maps API Key - free at https://api-portal.electricitymaps.com/
ELECTRICITY_MAPS_API_KEY=your_electricity_maps_key_here

# JWT Secret - use a long random string in production
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_secret_string

# Server port (default: 3000)
PORT=3000

# Optional: label shown in /health endpoint (helps identify which server is responding)
SERVER_NAME=web01
